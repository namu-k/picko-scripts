# Linting configuration

[flake8]
max-line-length = 120
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    *.egg-info
ignore =
    # E203: whitespace before ':'
    E203,
    # W503: line break before binary operator
    W503
per-file-ignores =
    __init__.py:F401
    picko/video/prompt_templates.py:E501
max-complexity = 18
