# Picko 환경변수 설정
# 이 파일을 .env로 복사한 뒤 실제 키를 입력하세요:
#   copy .env.example .env
# .env 값은 picko.config 로드 시 환경변수로 주입되며,
# config.yml의 api_key_env(OPENAI_API_KEY 등)에서 API 키로 사용됩니다.

# OpenAI API 키 (글쓰기용, 필수)
OPENAI_API_KEY=sk-your-key-here

# OpenRouter API 키 (OpenRouter 사용 시)
# OPENROUTER_API_KEY=sk-or-your-key-here

# Anthropic API 키 (Anthropic 사용 시)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Relay API 키 (Relay provider 사용 시)
RELAY_API_KEY=your-relay-key-here

# ─────────────────────────────────────────────────────────────
# Platform API (Optional - for engagement_sync.py)
# ─────────────────────────────────────────────────────────────

# Twitter/X API (metrics sync)
# TWITTER_BEARER_TOKEN=your-twitter-bearer-token
# TWITTER_API_KEY=your-api-key
# TWITTER_API_SECRET=your-api-secret
# TWITTER_ACCESS_TOKEN=your-access-token
# TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret

# Discovery Adapter APIs (Optional - for source discovery)
# Threads API (requires Meta App Review for /keyword_search)
# THREADS_ACCESS_TOKEN=your-threads-access-token

# Reddit API (OAuth app credentials)
# REDDIT_CLIENT_ID=your-reddit-client-id
# REDDIT_CLIENT_SECRET=your-reddit-client-secret

# Mastodon API
# MASTODON_ACCESS_TOKEN=your-mastodon-access-token
# MASTODON_INSTANCE=mastodon.social

# ─────────────────────────────────────────────────────────────
# Image API (Optional - for multimedia styles)
# ─────────────────────────────────────────────────────────────

# Unsplash API (for Photogram style backgrounds)
# Get keys at: https://unsplash.com/developers
# UNSPLASH_ACCESS_KEY=your-unsplash-access-key
# UNSPLASH_SECRET_KEY=your-unsplash-secret-key

# Pexels API (alternative image source)
# Get key at: https://www.pexels.com/api/
# PEXELS_API_KEY=your-pexels-api-key

# ─────────────────────────────────────────────────────────────
# Human Review Bot (Optional - for quality/discovery review)
# ─────────────────────────────────────────────────────────────

# Notification provider (telegram | slack)
# NOTIFICATION_PROVIDER=telegram

# Telegram bot credentials
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_CHAT_ID=your-telegram-chat-id

# Review timeout window in hours (default: 72)
# REVIEW_TIMEOUT_HOURS=72

# Review reminder interval in hours (default: 24)
# REVIEW_REMINDER_HOURS=24

# Slack bot credentials (alternative to Telegram)
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_CHANNEL_ID=C0123456789
